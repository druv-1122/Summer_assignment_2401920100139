class Solution:
    def isValidBST(self, root):
        def check(node, low, high):
            if not node:
                return True

            if node.val <= low or node.val >= high:
                return False

            left_valid = check(node.left, low, node.val)
            if not left_valid:
                return False

            right_valid = check(node.right, node.val, high)
            if not right_valid:
                return False

            return True

        return check(root, float("-inf"), float("inf"))
